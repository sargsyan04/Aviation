.pytest_cache/
.mypy_cache/
.pyre/
.pytype/
.cache/

# Test / coverage reports
.coverage
.coverage.*
coverage.xml
htmlcov/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# IDEs and editors
.vscode/
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Databases
*.sqlite3
db.sqlite3

# Static / build artifacts
staticfiles/
assets/
dist/

# Docker
docker-compose.override.yml
.env.docker

# Node (if frontend present)
node_modules/

# Sphinx / docs build
_build/
docs/_build/

