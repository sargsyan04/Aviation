# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/
.eggs/

# Virtual environments
.env
.env.*
venv/
venv*/
.venv/
.Python
__pypackages__/

